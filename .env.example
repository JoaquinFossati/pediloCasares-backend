# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Base de datos ──────────────────────────────────────────────────────────────
# En Railway: usar DATABASE_URL (provisto automáticamente por el plugin de PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# En desarrollo local: usar variables individuales (ignoradas si DATABASE_URL está definida)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deliverycs
DB_USER=postgres
DB_PASSWORD=yourpassword

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga
JWT_ACCESS_EXPIRES=24h
JWT_REFRESH_EXPIRES=7d

# ── Seguridad ─────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10
# Orígenes permitidos para CORS (separados por coma). En Railway poner la URL pública.
ALLOWED_ORIGINS=https://tu-app.up.railway.app

# ── Email (recuperación de contraseña) ────────────────────────────────────────
# Usar Gmail: habilitar "contraseñas de aplicación" en tu cuenta Google.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tucuenta@gmail.com
SMTP_PASS=tu_contrasena_de_app
